{
  "cleanUrls": true,
  "redirects": [
    { "source": "/", "destination": "/dashboard.html", "permanent": false }
  ],
  "headers": [
    {
      "source": "/dashboard.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/dashboard-data.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
