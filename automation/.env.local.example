# automation/.env.local — 실제 값으로 채워 automation/.env.local 로 저장 (gitignored, 커밋 금지)
# release/admin 공용 계정이면 CEP_ID/CEP_PW 만 채우면 됨.

# ── 자격증명 ──
CEP_ID=
CEP_PW=
# (선택) release/admin 계정이 다르면 개별 지정
# CEP_RELEASE_ID=
# CEP_RELEASE_PW=
# CEP_ADMIN_ID=
# CEP_ADMIN_PW=

# ── 호스트 (기본값 있음; 필요 시 override) ──
# CEP_RELEASE_BASE=https://release.listeningmind.com
# CEP_ADMIN_BASE=https://admins-rele.listeningmind.com

# ── 로그인 경로/셀렉터 (실제 페이지 확인 후 필요 시 조정) ──
# CEP_RELEASE_LOGIN_PATHS=/ko/login,/login
# CEP_ADMIN_LOGIN_PATHS=/login,/hubble/login
# SEL_LOGIN_ID=input[type="email"]
# SEL_LOGIN_PW=input[type="password"]
# SEL_LOGIN_SUBMIT=button[type="submit"]

# ── 어드민 프롬프트 폼 셀렉터 (Phase B; 실제 폼 확인 필요) ──
# SEL_ADMIN_PROMPT=textarea
# SEL_ADMIN_DISPLAYPOS=
# SEL_ADMIN_PREVIEW=
# SEL_ADMIN_SAVE=
# SEL_ADMIN_KRTAB=

# ── 서비스 재생성 셀렉터 (Phase C; 실제 페이지 확인 필요) ──
# SEL_CEP_SEARCH=input[type="text"]
# SEL_CEP_SEARCHBTN=button[type="submit"]
# SEL_CEP_QUOTA=

# ── 동작 옵션 ──
# CEP_HEADLESS=false      # 디버깅/반자동 로그인 시 브라우저 표시
# CEP_REQ_DELAY_MS=300
